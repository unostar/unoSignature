# Copy to local.env (gitignored) and fill in values.

# Live Firma workspace key (production).
FIRMA_API_KEY=

# Test Firma workspace key (no live credits; watermarked requests).
FIRMA_TEST_API_KEY=

# Use test key for scripts below.
FIRMA_USE_TEST_KEY=1

# Webhook signing secret from Firma (same as plugin settings).
FIRMA_WEBHOOK_SECRET=

# Default consultation template UUID for create-request.php.
TEMPLATE_ID=

# Site webhook endpoint for fake-webhook.php.
WEBHOOK_URL=https://example.test/wp-json/firma/v1/webhook

# Optional sample signer data for create-request.php.
SIGNER_EMAIL=test@example.com
SIGNER_FIRST_NAME=Test
SIGNER_LAST_NAME=Signer
SIGNER_TITLE=Mr
SIGNER_PHONE=+10000000000
SIGNER_BIRTHDATE=1990-01-01
SIGNER_ADDRESS=1 Test Street
SIGNER_CITY=Brisbane
SIGNER_STATE=QLD
SIGNER_POSTCODE=4000
SIGNER_COUNTRY=AU
